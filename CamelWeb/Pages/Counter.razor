@page "/progress"

<div class="container mt-4 text-center">
    <h2 style="color: #512BD4; font-weight: bold;">Мій шлях Camel 🐫</h2>
    <p class="text-muted">Тут ми замінили лічильник на твої успіхи!</p>

    <div style="display: flex; justify-content: space-around; gap: 15px; flex-wrap: wrap; margin-top: 30px;">
        
        @* Картка Англійської *@
        <div style="background: #f3f0ff; padding: 25px; border-radius: 20px; width: 220px; border: 2px solid #dcd3ff;">
            <h5 style="color: #512BD4;">English</h5>
            <p style="font-size: 32px; font-weight: bold; margin: 10px 0;">B1</p>
            <span style="font-size: 14px; color: #666;">Ціль: B2</span>
        </div>

        @* Картка Словника *@
        <div style="background: #fff9db; padding: 25px; border-radius: 20px; width: 220px; border: 2px solid #fff0a5;">
            <h5 style="color: #f59f00;">Словник</h5>
            <p style="font-size: 32px; font-weight: bold; margin: 10px 0;">15</p>
            <span style="font-size: 14px; color: #666;">слів вивчено</span>
        </div>

    </div>

    @* Велика лінія прогресу *@
    <div style="margin-top: 50px; padding: 20px; background: white; border-radius: 20px; border: 1px solid #eee;">
        <h4 style="margin-bottom: 20px;">Загальний прогрес 📈</h4>
        <div style="background: #eee; border-radius: 15px; height: 25px; width: 100%; overflow: hidden;">
            <div style="background: #512BD4; width: 40%; height: 100%; color: white; font-size: 14px; line-height: 25px;">
                40%
            </div>
        </div>
    </div>
</div>