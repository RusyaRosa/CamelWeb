@page "/grammar"

<div class="container-fluid mt-4">
    <div class="row">
        @* Ліве меню *@
        <div class="col-md-3 border-end">
            <h4 class="mb-4" style="color: #512BD4;">Граматика 🐫</h4>
            <div class="nav flex-column">
                <div class="p-2 mb-2" style="background: #512BD4; color: white; border-radius: 10px;">
                    ● Present Simple
                </div>
                <div class="p-2 mb-2 text-muted">
                    ○ Past Simple (скоро)
                </div>
            </div>
        </div>

        @* Права частина *@
        <div class="col-md-9 ps-4">
            <h1 class="fw-bold" style="color: #512BD4;">Present Simple</h1>
            <p class="text-muted">Простий теперішній час</p>

            @* Таблиця-шпаргалка *@
            <div class="row text-center mt-4 mb-5 p-3" style="background: #f8f9fa; border-radius: 20px; border: 1px solid #dee2e6;">
                <div class="col-md-4 border-end">
                    <h5 class="fw-bold text-primary">Ствердження</h5>
                    <hr />
                    <p>🐫 + V(s)</p>
                </div>
                <div class="col-md-4 border-end">
                    <h5 class="fw-bold text-danger">Заперечення</h5>
                    <hr />
                    <p>🐫 + don't/doesn't + V</p>
                </div>
                <div class="col-md-4">
                    <h5 class="fw-bold text-warning">Питання</h5>
                    <hr />
                    <p>Do/Does + 🐫 + V?</p>
                </div>
            </div>

            @* Деталі *@
            <div class="detailed-rules">
                <h3 class="border-bottom pb-2">🔹 Ствердження</h3>
                <p>I listen to music. 🐫 / She listen<b>s</b> to music.</p>

                <h3 class="border-bottom pb-2 text-danger mt-4">🔸 Заперечення</h3>
                <p>I <b>don't</b> eat meat. / He <b>doesn't</b> eat meat.</p>

                <h3 class="border-bottom pb-2 text-warning mt-4">❓ Питання</h3>
                <p><b>Do</b> you play? / <b>Does</b> he play?</p>

                <div class="p-4 mt-5 shadow-sm" style="background: #512BD4; color: white; border-radius: 25px;">
                    <h4>🐫 Маркери</h4>
                    <p class="mb-0">Always, Usually, Often, Sometimes, Never, Every day.</p>
                </div>
            </div>
        </div>
    </div>
</div>