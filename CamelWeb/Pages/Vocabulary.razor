@page "/vocabulary"

<div class="container mt-4">
    <div class="text-center mb-5 p-4" style="background: #512BD4; color: white; border-radius: 25px; shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <h1 class="fw-bold">Мій Словник 🐫📚</h1>
        <p class="mb-0">Зараз я вивчаю: <span class="badge bg-warning text-dark fs-5">@selectedLanguage</span></p>
    </div>

    @* Кнопки вибору мови *@
    <div class="d-flex justify-content-center gap-3 mb-5">
        <button class="btn btn-outline-primary fw-bold" @onclick='() => SelectLanguage("English 🇬🇧")'>English</button>
        <button class="btn btn-outline-danger fw-bold" @onclick='() => SelectLanguage("Turkish 🇹🇷")'>Turkish</button>
        <button class="btn btn-outline-info fw-bold" @onclick='() => SelectLanguage("Icelandic 🇮🇸")'>Icelandic</button>
    </div>

    @* Таблиця зі словами *@
    <div class="card shadow-sm border-0" style="border-radius: 20px;">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="p-3">Слово</th>
                        <th class="p-3">Переклад</th>
                        <th class="p-3">Приклад</th>
                    </tr>
                </thead>
                <tbody>
                    @if (selectedLanguage.Contains("English"))
                    {
                        <tr><td class="p-3"><b>Ambition</b></td><td>Амбіція</td><td>I have a big ambition. 🐫</td></tr>
                        <tr><td class="p-3"><b>Developer</b></td><td>Розробник</td><td>Ruslana is a software developer.</td></tr>
                    }
                    else if (selectedLanguage.Contains("Turkish"))
                    {
                        <tr><td class="p-3"><b>Merhaba</b></td><td>Привіт</td><td>Merhaba, nasılsın?</td></tr>
                        <tr><td class="p-3"><b>Arkadaş</b></td><td>Друг</td><td>O benim en iyi arkadaşım.</td></tr>
                    }
                    else
                    {
                        <tr><td class="p-3"><b>Eldfjall</b></td><td>Вулкан</td><td>Ísland er land eldfjalla.</td></tr>
                        <tr><td class="p-3"><b>Tölva</b></td><td>Комп'ютер</td><td>Ég elska nýju tölvuna mína.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private string selectedLanguage = "English 🇬🇧";

    private void SelectLanguage(string lang)
    {
        selectedLanguage = lang;
    }
}